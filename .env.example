# 🧿 OmniSint Elite v1.1.0 - Config Template
# Rename this file to .env and fill in your keys

# --- API KEYS ---
# Get yours at https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# Get yours at https://account.shodan.io/
SHODAN_API_KEY=

# Get yours at https://hunter.io/api
HUNTER_API_KEY=

# --- NETWORK SETTINGS ---
# Set to true if you have Tor (SOCKS5) running on 127.0.0.1:9050
TOR_ENABLED=false

# Caching time in seconds (Default: 12 hours)
CACHE_TTL=43200

# Global timeout for requests
DEFAULT_TIMEOUT=15
